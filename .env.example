OPENROUTER_API_KEY=your_openrouter_api_key

# OpenRouter models (https://openrouter.ai/models)
EMBEDDING_MODEL=openai/text-embedding-3-small
LLM_MODEL=google/gemini-2.0-flash-001
QUERY_EXPANSION_MODEL=openai/gpt-4o-mini

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=documents
EMBEDDING_DIMENSIONS=1536

# Ingestion
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K=5

# Multi-query retrieval (LLM rewrites question into variants, then fuses results)
MULTI_QUERY_ENABLED=true
MULTI_QUERY_COUNT=3

# Hybrid search (vector + BM25 keyword, fused with RRF)
HYBRID_SEARCH_ENABLED=true
HYBRID_KEYWORD_CANDIDATE_MULTIPLIER=10

# Reranking (cross-encoder via OpenRouter, refines chunks before LLM)
RERANK_ENABLED=true
RERANK_MODEL=cohere/rerank-v3.5
RERANK_CANDIDATE_LIMIT=20
RERANK_MAX_DOC_CHARS=2000
